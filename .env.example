# Copy to .env and fill in values. Never commit .env.
# All VITE_* vars are baked into the JS bundle at build time by Vite.
# Set production values in Cloudflare Pages → Settings → Environment variables.

# Airtable — Abandoned Carts capture
VITE_AIRTABLE_TOKEN=

# Google Apps Script — click / UTM logging
VITE_SHEETS_ENDPOINT=

# Admin — password for /admin/slug (set real value in Cloudflare, not here)
VITE_ADMIN_PASSWORD=
